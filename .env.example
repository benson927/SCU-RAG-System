# Optional Gemini acceleration
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL document management
DATABASE_URL=postgresql://user:password@host:5432/database
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SECRET=replace-with-a-long-random-secret
ADMIN_TOKEN_TTL_SECONDS=3600
MAX_PDF_SIZE_BYTES=20971520
ADMIN_LOGIN_RATE_LIMIT=5
RAG_RATE_LIMIT=20
RATE_LIMIT_WINDOW_SECONDS=60
TRUST_PROXY_HEADERS=false
MAX_QUERY_LENGTH=1000
RAG_TIMEOUT_SECONDS=120
RAG_MAX_CONCURRENCY=2

# S3-compatible object storage
STORAGE_ENDPOINT=https://your-s3-compatible-endpoint
STORAGE_REGION=auto
STORAGE_BUCKET=scu-law-documents
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=true

# Runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
