# Local development only. Replace every password and secret before sharing
# the environment or deploying it outside your machine.

POSTGRES_DB=scu_rag
POSTGRES_USER=scu_rag
POSTGRES_PASSWORD=scu_rag_dev
POSTGRES_PORT=5432
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

MINIO_ROOT_USER=scu_minio
MINIO_ROOT_PASSWORD=scu_minio_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
STORAGE_BUCKET=scu-law-documents
STORAGE_REGION=us-east-1
STORAGE_CONNECT_TIMEOUT_SECONDS=5
STORAGE_READ_TIMEOUT_SECONDS=30
STORAGE_MAX_ATTEMPTS=3

ADMIN_PASSWORD=scu-admin-dev
ADMIN_TOKEN_SECRET=replace-this-for-any-shared-environment
ADMIN_LOGIN_RATE_LIMIT=5
RAG_RATE_LIMIT=20
RATE_LIMIT_WINDOW_SECONDS=60
TRUST_PROXY_HEADERS=false
MAX_QUERY_LENGTH=1000
RAG_TIMEOUT_SECONDS=120
RAG_MAX_CONCURRENCY=2
BACKEND_PORT=8000
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=gemma3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
